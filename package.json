{
  "name": "@combat-ui/core",
  "version": "0.0.1",
  "description": "A responsive, customizable web component framework targeting modern baseline web standards.",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "UI",
    "CSS",
    "HTML",
    "responsive",
    "web components"
  ],
  "license": "MIT",
  "authors": [
    {
      "name":"Christiaan van Dam",
      "email":"chris@combat.nl" 
    },
    {
      "name":"Jessica Benedictus",
      "email":"jessica@combat.nl"
    }
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./src/index.ts",
    "./dist/combat-ui.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/combat-ui.js"
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:docs": "vite docs --config vite.config.ts",
    "build": "npm run clean && npm run typecheck && npm run build:lib && npm run build:docs",
    "build:lib": "vite build --config vite.config.ts",
    "build:docs": "vite build docs --config vite.config.ts --outDir ../dist-docs --emptyOutDir",
    "typecheck": "tsc -b",
    "typecheck:clean": "tsc -b --clean",
    "check": "npm run typecheck && npm run check:css && npm run check:html",
    "check:css": "stylelint \"src/**/*.css\" \"docs/**/*.css\" \"examples/**/*.css\"",
    "check:html": "eslint \"docs/**/*.html\" \"examples/**/*.html\"",
    "clean": "rimraf dist dist-docs .tsbuildinfo"
  },
  "browserslist": [
    "baseline 2025 with downstream"
  ],
  "devDependencies": {
    "@types/node": "24.3.0",
    "@html-eslint/eslint-plugin": "0.60.0",
    "@html-eslint/parser": "0.60.0",
    "eslint": "10.3.0",
    "eslint-plugin-baseline-js": "0.6.2",
    "eslint-plugin-compat": "7.0.2",
    "rimraf": "6.1.3",
    "stylelint": "17.11.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-plugin-use-baseline": "1.4.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-dts": "5.0.0"
  }
}
